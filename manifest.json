{
  "id": "co-parenting",
  "name": "Co-Parenting",
  "version": "1.2.0",
  "description": "Shared custody coordination for split households — per-child schedules, countersigned schedule swaps, a tamper-evident message log, and handoff notes. Custody days flow to the household Calendar so kids always know where they are.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "family",
  "tags": [
    "co-parenting",
    "custody",
    "schedule",
    "family"
  ],
  "data_access": {
    "reads": [
      "family.members"
    ],
    "writes": []
  },
  "exports": [
    "calendar_events"
  ],
  "permissions": {
    "default_audience": "adults",
    "requires_approval": false
  },
  "contexts": [
    "household",
    "shared_space"
  ],
  "storage": "db",
  "db_plaintext_columns": [
    "note_date",
    "start_date",
    "end_date",
    "anchor_date",
    "pattern",
    "cycle",
    "cycle_length",
    "exchange_time",
    "day",
    "is_transition"
  ],
  "partner_link": {
    "table": "partner_config",
    "member_column": "member_id",
    "partner_id_column": "partner_id",
    "session_id_column": "session_id",
    "require_role": "adult"
  },
  "row_policies": {
    "partner_config": {
      "kind": "owner_only",
      "member_column": "member_id",
      "adults_bypass": false,
      "endpoint_writes_only": true
    },
    "schedules": {
      "kind": "adult_writable",
      "audit_writes": true
    },
    "overrides": {
      "kind": "adult_writable",
      "audit_writes": true
    },
    "custody_days": {
      "kind": "adult_writable",
      "retain_days": {
        "default": 400,
        "timestamp_column": "day"
      }
    },
    "swap_requests": {
      "kind": "party_scoped",
      "member_columns": [
        "requester_id",
        "responder_id"
      ],
      "self_column": "requester_id",
      "audit_writes": true
    },
    "swap_agreements": {
      "kind": "endpoint_only",
      "read": "adult"
    },
    "messages": {
      "kind": "couple_scoped",
      "self_column": "author_id",
      "participant_columns": [
        "author_id",
        "recipient_id"
      ],
      "partner_table": "partner_config",
      "partner_member_column": "member_id",
      "partner_id_column": "partner_id",
      "require_reciprocal": true,
      "endpoint_writes_only": true
    },
    "handoff_notes": {
      "kind": "endpoint_only",
      "read": "adult"
    }
  },
  "append_only_records": {
    "messages": {
      "table": "messages",
      "allowed_columns": [
        "recipient_id",
        "body"
      ],
      "writer_column": "author_id",
      "created_at_column": "sent_at",
      "write_acl": {
        "require_role": "adult"
      },
      "max_text_lengths": {
        "body": 5000,
        "recipient_id": 120
      }
    },
    "handoff_notes": {
      "table": "handoff_notes",
      "allowed_columns": [
        "child_id",
        "note_date",
        "category",
        "body"
      ],
      "writer_column": "created_by",
      "created_at_column": "created_at",
      "write_acl": {
        "require_role": "adult"
      },
      "allowed_values": {
        "category": [
          "health",
          "school",
          "mood",
          "items",
          "general"
        ]
      },
      "max_text_lengths": {
        "child_id": 120,
        "note_date": 20,
        "category": 20,
        "body": 2000
      }
    }
  },
  "agreements": {
    "swap_agreements": {
      "participant_columns": [
        "requester_id",
        "responder_id"
      ],
      "agreement_columns": {
        "requester_id": "requester_agreed",
        "responder_id": "responder_agreed"
      },
      "status_column": "status",
      "pending_value": "pending",
      "locked_value": "locked",
      "locked_at_column": "locked_at",
      "updated_at_column": "updated_at",
      "init_from_table": "swap_requests",
      "init_columns": [
        "requester_id",
        "responder_id"
      ]
    }
  },
  "store_acls": {
    "calendar_events": {
      "write": {
        "require_role": "adult"
      }
    }
  },
  "agenda": {
    "kind": "event",
    "label": "Custody",
    "source": {
      "kind": "sql",
      "query": "SELECT id AS id, title AS title, subtitle AS subtitle, day AS when_at, child_id AS member_id FROM app_co_parenting__custody_days WHERE day = :today ORDER BY is_transition DESC, id LIMIT 10"
    }
  },
  "glance": {
    "source": {
      "kind": "sql",
      "query": "SELECT title AS title, subtitle AS subtitle, day AS at, child_id AS member_id FROM app_co_parenting__custody_days WHERE is_transition = 1 AND day >= :today ORDER BY day LIMIT 3"
    },
    "display": {
      "template": "list",
      "title": "title",
      "subtitle": "subtitle",
      "when": "at",
      "owner": "member_id"
    }
  },
  "reports": {
    "change_history": true,
    "views": [
      {
        "id": "custody_record",
        "title": "Custody record",
        "description": "Which parent each child was with, day by day, including exchanges.",
        "source": {
          "kind": "sql",
          "query": "SELECT day AS day, child_id AS child, parent_id AS parent, from_parent_id AS from_parent, source AS source, exchange_time AS exchange_time FROM app_co_parenting__custody_days WHERE day >= :range_start AND day <= :range_end ORDER BY day, child_id"
        },
        "columns": [
          { "key": "day", "label": "Date", "format": "date" },
          { "key": "child", "label": "Child", "format": "member" },
          { "key": "parent", "label": "With", "format": "member" },
          { "key": "from_parent", "label": "Exchanged from", "format": "member" },
          { "key": "exchange_time", "label": "Exchange time" },
          { "key": "source", "label": "Set by" }
        ]
      },
      {
        "id": "message_log",
        "title": "Message log",
        "description": "Every message between the co-parents, oldest first. Append-only — messages cannot be edited or deleted.",
        "source": {
          "kind": "sql",
          "query": "SELECT sent_at AS sent_at, author_id AS author, recipient_id AS recipient, body AS body FROM app_co_parenting__messages WHERE sent_at >= :range_start AND sent_at <= :range_end ORDER BY sent_at"
        },
        "columns": [
          { "key": "sent_at", "label": "Sent", "format": "datetime" },
          { "key": "author", "label": "From", "format": "member" },
          { "key": "recipient", "label": "To", "format": "member" },
          { "key": "body", "label": "Message" }
        ]
      },
      {
        "id": "schedule_changes",
        "title": "Schedule changes",
        "description": "Every exception to the standing rotation — applied swaps and one-off adjustments.",
        "source": {
          "kind": "sql",
          "query": "SELECT start_date AS start_date, end_date AS end_date, child_id AS child, parent_id AS parent, reason AS reason, created_by AS created_by, created_at AS created_at FROM app_co_parenting__overrides WHERE start_date >= :range_start AND start_date <= :range_end ORDER BY start_date"
        },
        "columns": [
          { "key": "start_date", "label": "From", "format": "date" },
          { "key": "end_date", "label": "To", "format": "date" },
          { "key": "child", "label": "Child", "format": "member" },
          { "key": "parent", "label": "With", "format": "member" },
          { "key": "reason", "label": "Reason" },
          { "key": "created_by", "label": "Entered by", "format": "member" },
          { "key": "created_at", "label": "Entered", "format": "datetime" }
        ]
      },
      {
        "id": "swap_requests",
        "title": "Swap requests",
        "description": "Requested schedule changes and how each was answered.",
        "source": {
          "kind": "sql",
          "query": "SELECT created_at AS created_at, child_id AS child, start_date AS start_date, end_date AS end_date, requester_id AS requester, responder_id AS responder, to_parent_id AS to_parent, status AS status, note AS note FROM app_co_parenting__swap_requests WHERE created_at >= :range_start AND created_at <= :range_end ORDER BY created_at"
        },
        "columns": [
          { "key": "created_at", "label": "Requested", "format": "datetime" },
          { "key": "child", "label": "Child", "format": "member" },
          { "key": "start_date", "label": "From", "format": "date" },
          { "key": "end_date", "label": "To", "format": "date" },
          { "key": "requester", "label": "Requested by", "format": "member" },
          { "key": "responder", "label": "Asked of", "format": "member" },
          { "key": "to_parent", "label": "Proposed parent", "format": "member" },
          { "key": "status", "label": "Outcome" },
          { "key": "note", "label": "Note" }
        ]
      },
      {
        "id": "handoff_notes",
        "title": "Handoff notes",
        "description": "Notes passed at exchanges — health, school, mood, and items sent along.",
        "source": {
          "kind": "sql",
          "query": "SELECT note_date AS note_date, child_id AS child, category AS category, body AS body, created_by AS created_by FROM app_co_parenting__handoff_notes WHERE note_date >= :range_start AND note_date <= :range_end ORDER BY note_date"
        },
        "columns": [
          { "key": "note_date", "label": "Date", "format": "date" },
          { "key": "child", "label": "Child", "format": "member" },
          { "key": "category", "label": "Category" },
          { "key": "body", "label": "Note" },
          { "key": "created_by", "label": "Written by", "format": "member" }
        ]
      }
    ]
  },
  "nav": {
    "label": "Co-Parenting"
  },
  "widget": {
    "label": "Co-Parenting",
    "size": "small"
  },
  "icon": "🧭",
  "resource_limits": {
    "max_db_bytes": 52428800
  }
}
